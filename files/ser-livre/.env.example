# Senha do banco de dados PostgreSQL
DB_PASSWORD=SuaSenhaSeguraAqui123!

# Chave secreta para autenticação JWT (gere uma chave aleatória)
# Dica: rode "openssl rand -hex 32" no terminal para gerar
JWT_SECRET=sua-chave-secreta-aqui-trocar-em-producao

# Porta do backend (não precisa mudar normalmente)
PORT=3001
