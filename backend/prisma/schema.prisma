// ============================================================
// ESQUEMA DO BANCO DE DADOS — Programa Ser Livre
//
// Este arquivo define TODAS as tabelas do banco de dados.
// O Prisma transforma isso em tabelas PostgreSQL automaticamente.
//
// Pense em cada "model" como uma planilha:
// - User       = planilha de usuários (equipe + pacientes)
// - Patient    = planilha de dados clínicos dos pacientes
// - Cycle      = planilha de ciclos (cada ciclo = 16 semanas)
// - WeekCheck  = planilha de checklist semanal
// - ScoreEntry = planilha de scores clínicos
// - Alert      = planilha de alertas automáticos
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// USUÁRIOS — Quem acessa o sistema
// Tanto a equipe quanto os pacientes são usuários.
// O "role" define o que cada um pode ver/fazer.
// ──────────────────────────────────────────────
model User {
  id        String   @id  // UUID from Supabase Auth
  email     String   @unique
  name      String
  role      Role     @default(PACIENTE)
  avatarUrl String?  // URL da foto de perfil
  phone     String?
  specialty String?  // Especialidade do profissional (nutricionista, psicóloga, etc.)
  active    Boolean  @default(true)
  emailVerified   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação: um usuário pode ser paciente
  patient   Patient?

  // Relação: quem da equipe preencheu os dados
  weekChecks  WeekCheck[]  @relation("filledBy")
  scoresFilled ScoreEntry[] @relation("filledBy")

  inviteTokens    InviteToken[]
  resetTokens     ResetToken[]

  // Agendamentos (como profissional ou como criador)
  appointmentsAsStaff    Appointment[]    @relation("appointmentStaff")
  appointmentsCreated    Appointment[]    @relation("appointmentCreator")

  // Comunicação
  templatesCreated       MessageTemplate[] @relation("templateCreator")
  messagesSent           MessageLog[]      @relation("messageSender")

  // Activity log
  activityLogs           ActivityLog[]     @relation("activityMember")
}

// Papéis possíveis no sistema
enum Role {
  ADMIN           // Danilo (TI) — acesso total ao sistema
  MEDICA          // Dra. Mariana — vê tudo, recebe alertas vermelhos
  ENFERMAGEM      // Juliana — preenche checklist, aplica medicação
  NUTRICIONISTA   // Patricia — preenche scores, plano alimentar
  PSICOLOGA       // Renata — preenche dados psicológicos
  TREINADOR       // Carlos — marca treinos realizados
  PACIENTE        // Paciente — só visualiza seus próprios dados
}

// ──────────────────────────────────────────────
// PACIENTES — Dados clínicos
// Cada paciente tem um registro com seus dados
// médicos e o plano escolhido.
// ──────────────────────────────────────────────
model Patient {
  id            Int      @id @default(autoincrement())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dados clínicos
  birthDate     DateTime?
  initialWeight Float       // Peso inicial (kg)
  currentWeight Float       // Peso atual (kg)
  height        Float?      // Altura (cm)

  // Plano escolhido
  plan          Plan        @default(ESSENTIAL)
  startDate     DateTime    @default(now())

  // Relacionamentos
  cycles        Cycle[]         // Ciclos de tratamento
  alerts        Alert[]         // Alertas gerados
  appointments  Appointment[]   // Agendamentos
  messageLogs   MessageLog[]    // Histórico de mensagens
  activityLogs  ActivityLog[]   // Log de atividades

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Os 6 planos do Programa Ser Livre
enum Plan {
  PLATINUM_PLUS   // Tier 1 — acompanhamento máximo
  GOLD_PLUS       // Tier 1
  PLATINUM        // Tier 2 — acompanhamento intermediário
  GOLD            // Tier 2
  ESSENTIAL_PLUS  // Tier 3 — acompanhamento essencial
  ESSENTIAL       // Tier 3
}

// ──────────────────────────────────────────────
// CICLOS — Cada ciclo = 16 semanas de tratamento
// Um paciente pode fazer vários ciclos ao longo
// do tempo (Ciclo 1, Ciclo 2, etc.)
// ──────────────────────────────────────────────
model Cycle {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  number      Int      // Número do ciclo (1, 2, 3...)
  currentWeek Int      @default(1)  // Semana atual (1 a 16)
  status      CycleStatus @default(ACTIVE)
  startDate   DateTime @default(now())
  endDate     DateTime?

  // Relacionamentos
  weekChecks  WeekCheck[]   // Checklists semanais
  scores      ScoreEntry[]  // Scores registrados

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([patientId, number])
}

enum CycleStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

// ──────────────────────────────────────────────
// CHECKLIST SEMANAL — O que foi feito cada semana
// Cada linha = 1 semana de 1 ciclo de 1 paciente.
// As "meninas da equipe" preenchem isso.
// ──────────────────────────────────────────────
model WeekCheck {
  id          Int      @id @default(autoincrement())
  cycleId     Int
  cycle       Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  weekNumber  Int      // 1 a 16
  weekDate    DateTime?

  // Enfermagem
  tirzepatida       Boolean  @default(false)
  tirzepatidaDose   String?  // Ex: "2.5mg", "5mg", "7.5mg"
  terapiaInjetavel  Boolean? // null = não se aplica ao plano
  pesagem           Boolean  @default(false)
  pesoRegistrado    Float?   // Peso medido nesta semana

  // Psicóloga
  sessaoPsicologia  Boolean? // null = não se aplica

  // Bioimpedância
  bioimpedancia     Boolean  @default(false)

  // Pulsare (Treinos)
  treino1           Boolean  @default(false)
  treino2           Boolean  @default(false)
  treino3           Boolean? // null = plano só tem 2 treinos

  // Nutricionista (apenas nas semanas 4, 8, 12, 16)
  nutriAvaliacaoCompleta Boolean?
  nutriPlanoAlimentar    Boolean?
  nutriScoresClinicos    Boolean?

  // Bioimpedância — composição corporal
  massaMagra   Float?   // Massa magra registrada (kg)
  massaGordura Float?   // Massa gorda registrada (kg)

  // Controle
  observations String?
  filledById   String?
  filledBy     User?    @relation("filledBy", fields: [filledById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([cycleId, weekNumber])
}

// ──────────────────────────────────────────────
// SCORES CLÍNICOS — Os 3 sistemas de pontuação
// Preenchido mensalmente pela nutricionista.
// O sistema calcula o total e gera alertas.
// ──────────────────────────────────────────────
model ScoreEntry {
  id          Int      @id @default(autoincrement())
  cycleId     Int
  cycle       Cycle    @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  month       String   // Rótulo do mês (ex: "Mar/26")

  // ── SCORE METABÓLICO (8 a 24 pts) ──
  // Pilar 1: Composição corporal
  gorduraVisceral   Int   // 1-3
  massaMuscular     Int   // 1-3
  // Pilar 2: Inflamação
  pcrUltrassensivel Int   // 1-3
  ferritina         Int   // 1-3
  // Pilar 3: Controle glicêmico
  hemoglobinaGlicada Int  // 1-3
  acidoUrico        Int   // 1-3
  // Pilar 4: Cardiovascular
  triglicerideosHdl Int   // 1-3
  circAbdominal     Int   // 1-3

  // ── SCORE BEM-ESTAR (6 a 18 pts) ──
  gastrointestinal  Int   // 1-3
  libido            Int   // 1-3
  doresArticulares  Int   // 1-3
  autoestimaMental  Int   // 1-3
  energiaPerformance Int  // 1-3
  sonoCefaleia      Int   // 1-3

  // ── SCORE MENTAL (3 a 9 pts) ──
  consistenciaAlimentar Int  // 1-3
  gestaoEmocional       Int  // 1-3
  movimentoPresenca     Int  // 1-3

  // Totais (calculados automaticamente)
  totalMetabolico   Int
  totalBemEstar     Int
  totalMental       Int

  // Classificações (calculadas)
  statusMetabolico  String  // CRITICO, TRANSICAO, SAUDAVEL, ELITE
  statusBemEstar    String  // CRITICO, ALERTA, EXCELENTE
  statusMental      String  // RECAIDA, CONSTRUCAO, ELITE

  // Quem preencheu
  filledById   String?
  filledBy     User?    @relation("filledBy", fields: [filledById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([cycleId, month])
}

// ──────────────────────────────────────────────
// ALERTAS — Gerados automaticamente pelos scores
// Vermelho = Dra. Mariana precisa ver
// Amarelo = Equipe precisa ficar atenta
// ──────────────────────────────────────────────
model Alert {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  type        AlertType
  severity    AlertSeverity
  message     String
  action      String     // Conduta sugerida
  resolved    Boolean    @default(false)
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
}

enum AlertType {
  METABOLICO
  BEM_ESTAR
  MENTAL
  ENGAGEMENT
}

enum AlertSeverity {
  RED     // Vermelho — avisar Dra. Mariana
  YELLOW  // Amarelo — equipe ficar atenta
}

// ──────────────────────────────────────────────
// STATE BLOB — Persistência do estado do frontend
// Armazena JSON arbitrário indexado por chave.
// Permite que múltiplos usuários compartilhem os
// mesmos dados independente do dispositivo/browser.
// ──────────────────────────────────────────────
model StateBlob {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// AGENDAMENTOS — Eventos da equipe com pacientes
// Tipos com lembrete WhatsApp automático:
//   CONSULTA_MEDICA, CONSULTA_NUTRI, EXAME
// Tipo apenas visual para equipe:
//   OUTRO
// ──────────────────────────────────────────────
model Appointment {
  id          Int             @id @default(autoincrement())
  patientId   Int?
  patient     Patient?        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId     String?
  staff       User?           @relation("appointmentStaff", fields: [staffId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?           @relation("appointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  type        AppointmentType
  title       String?         // descrição / nome do evento
  date        DateTime        // data e hora
  notes       String?

  sendReminder  Boolean  @default(false) // true para CONSULTA e EXAME
  reminderSent  Boolean  @default(false) // evita reenvio duplo

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AppointmentType {
  CONSULTA_MEDICA   // Consulta com a médica
  CONSULTA_NUTRI    // Consulta com nutricionista
  EXAME             // Exame laboratorial
  OUTRO             // Evento interno (só equipe)
}

// ──────────────────────────────────────────────
// TEMPLATES DE MENSAGEM
// Templates reutilizáveis com variáveis {{nome}},
// {{peso_atual}}, {{semana}}, etc.
// ──────────────────────────────────────────────
model MessageTemplate {
  id          Int      @id @default(autoincrement())
  name        String   // Nome interno do template
  category    String   // boas_vindas | resultado | conquista | lembrete | agendamento | custom
  body        String   // Texto com variáveis {{nome}}, {{peso_atual}}, etc.
  isSystem    Boolean  @default(false) // templates padrão do sistema
  active      Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("templateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        MessageLog[]
}

// ──────────────────────────────────────────────
// HISTÓRICO DE MENSAGENS ENVIADAS
// ──────────────────────────────────────────────
model MessageLog {
  id          Int      @id @default(autoincrement())
  patientId   Int?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  templateId  Int?
  template    MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentById    String?
  sentBy      User?    @relation("messageSender", fields: [sentById], references: [id], onDelete: SetNull)

  phone       String?  // número que recebeu (null para mensagens internas do sistema)
  body        String   // texto final enviado (após substituição de variáveis)
  channel     String   @default("whatsapp") // whatsapp | email | interno
  status      String   @default("sent")     // sent | failed | pending
  error       String?

  createdAt   DateTime @default(now())
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  patientId   Int?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  patientName String?
  memberId    String?
  member      User?    @relation("activityMember", fields: [memberId], references: [id], onDelete: SetNull)
  memberName  String?
  detail      String?
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

model InviteToken {
  id          Int      @id @default(autoincrement())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model ResetToken {
  id          Int      @id @default(autoincrement())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  used        Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}
